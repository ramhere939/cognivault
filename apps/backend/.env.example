# ─────────────────────────────────────────
#  Autonomous Knowledge Intelligence Platform
#  Backend Environment Configuration
# ─────────────────────────────────────────

# Required: Your Google AI Studio API key
GEMINI_API_KEY=your_gemini_api_key_here

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database paths (relative to backend root)
SQLITE_PATH=./data/sqlite/knowledge.db
CHROMA_PATH=./data/chroma
GRAPHS_PATH=./data/graphs
UPLOADS_PATH=./data/uploads

# Gemini model configuration
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Pipeline tuning
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=50
MAX_RETRIEVAL_CHUNKS=10
RERANK_TOP_K=5
RELATIONSHIP_SIMILARITY_THRESHOLD=0.72

# CORS (frontend dev server)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
